# Copy this to .env and fill in real values before running in production
DATABASE_URL=sqlite:///./emotion_learning.db
SECRET_KEY=CHANGE_ME_use_a_long_random_string
RL_MODEL_PATH=./models/ppo_model.zip
FACIAL_MODEL_PATH=./models/facial_emotion.pth
DEBUG=False

# ── AI Tutor LLM options (pick one or leave all blank for rule-based mode) ──
# Option 1: OpenAI (requires account + credits)
# OPENAI_API_KEY=sk-...

# Option 2: HuggingFace Inference API (free tier at huggingface.co/settings/tokens)
# HF_API_TOKEN=hf_...
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.1   # optional, this is the default

# Option 3: Ollama (local LLM, install from ollama.ai then: ollama pull llama3)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Emotion detection ──
# Override the HuggingFace emotion model (downloads on first use, ~300 MB)
# HF_EMOTION_MODEL=trpakov/vit-face-expression
